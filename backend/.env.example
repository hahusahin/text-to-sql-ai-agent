# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# PostgreSQL connection string for the OWNER role (app). Used by Alembic
# migrations and the seed script — anything that creates tables or writes data.
# Local dev values match docker-compose.
DATABASE_URL=postgresql://app:app_local_dev@localhost:5432/manufacturing

# PostgreSQL connection string for the SELECT-only role (readonly_user). The app
# runtime connects as this — even if the LLM emits DROP TABLE, this role can't run
# it. The role + password are created by the readonly_role migration.
# In production, rotate this password (ALTER ROLE ... PASSWORD) and keep it secret.
DATABASE_URL_READONLY=postgresql://readonly_user:readonly_local_dev@localhost:5432/manufacturing

# Optional. Database the execution-accuracy eval (backend/eval/) runs against. It
# MUST point at the local dataset the ground truth was captured from — not production,
# whose seeded values differ. Defaults to the local read-only role, so you only set
# this to override. Never point it at the deployed DB.
EVAL_DATABASE_URL=postgresql://readonly_user:readonly_local_dev@localhost:5432/manufacturing

# Shared secret the gateway must send as the `X-API-Key` header on every request.
# The only auth layer: stops open abuse of the public backend URL. Must match the
# frontend's AI_SERVICE_API_KEY. Generate a random value; rotate in production.
API_KEY=dev_local_api_key

# Max time (ms) any single SQL statement may run before Postgres cancels it.
# Runaway-query protection: a heavy query can't tie up a pooled connection forever.
DB_STATEMENT_TIMEOUT_MS=5000

# OpenAI API key — create at https://platform.openai.com/api-keys. Real key only in .env, never committed.
OPENAI_API_KEY=sk-...

# Chat model for text-to-SQL.
OPENAI_MODEL=gpt-5.4-mini
