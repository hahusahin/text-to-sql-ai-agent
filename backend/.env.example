# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# PostgreSQL connection string used by the AI service (asyncpg, raw driver).
# Local dev values match docker-compose.
DATABASE_URL=postgresql://app:app_local_dev@localhost:5432/manufacturing

# OpenAI API key — create at https://platform.openai.com/api-keys. Real key only in .env, never committed.
OPENAI_API_KEY=sk-...

# Chat model for text-to-SQL.
OPENAI_MODEL=gpt-5.4-mini
