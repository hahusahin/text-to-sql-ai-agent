# Base URL of the FastAPI AI service that the gateway proxies to.
# Copy this file to .env.local and adjust if your backend runs elsewhere.
AI_SERVICE_URL=http://localhost:8000

# Shared secret the gateway sends as `X-API-Key` to the AI service.
# Must match the backend's API_KEY. Server-side only — never exposed to the browser.
AI_SERVICE_API_KEY=dev_local_api_key
